# --- ORDER BOOK CLASS ---
class OrderBook:
    def __init__(self):
        self.buy_orders = []   # Format: {"user": str, "price": float, "amount": float, "id": int}
        self.sell_orders = []  # Sorted ascending by price
        self.order_counter = 0

    def add_order(self, side, user, price, amount):
        self.order_counter += 1
        order = {"id": self.order_counter, "user": user, "price": price, "amount": amount}
        
        if side == "BUY":
            self.buy_orders.append(order)
            # Sort descending: Highest bidders at the top
            self.buy_orders.sort(key=lambda x: x["price"], reverse=True)
        else:
            self.sell_orders.append(order)
            # Sort ascending: Lowest sellers at the top
            self.sell_orders.sort(key=lambda x: x["price"])
        
        return order

# --- TRADING PLATFORM SYSTEM CORE ---
class SwampExchange:
    def __init__(self):
        self.users = {}       # Database: {username: {balances: {USD: x, BTC: y}, wallet: address}}
        self.order_book = OrderBook()
        self.trade_history = []

    def register_user(self, username):
        """Creates a local profile and attaches an automated cryptographic BTC address."""
        if username in self.users:
            print(f"[-] User {username} already registered.")
            return
        
        priv_key, btc_addr = generate_mock_btc_wallet()
        self.users[username] = {
            "balances": {"USD": 0.0, "BTC": 0.0},
            "btc_address": btc_addr,
            "private_key_secured": priv_key
        }
        print(f"[+] User Registered: {username}")
        print(f"    Allocated BTC Deposit Address: {btc_addr}")

    def deposit_funds(self, username, currency, amount):
        if username not in self.users:
            return
        self.users[username]["balances"][currency] += amount
        print(f"[*] Deposit Confirmed: {username} credited +{amount} {currency}")

    def print_balances(self):
        print(f"\n--- CURRENT EXCHANGE INTERNAL BALANCE LEDGER ({get_timestamp()}) ---")
        print(f"{'User':<12} | {'USD Balance':<15} | {'BTC Balance':<15} | {'Wallet Address'}")
        print("-" * 80)
        for user, profile in self.users.items():
            bal = profile["balances"]
            print(f"{user:<12} | ${bal['USD']:<14,.2f} | {bal['BTC']:<14:.4f} BTC | {profile['btc_address']}")
        print("-" * 80)

    def match_orders(self):
        """Executes clearing house matching engine math logic."""
        while self.order_book.buy_orders and self.order_book.sell_orders:
            highest_bid = self.order_book.buy_orders[0]
            lowest_ask = self.order_book.sell_orders[0]

            # Condition for execution: Buy price must match or exceed the sell price
            if highest_bid["price"] >= lowest_ask["price"]:
                # Match price is dictated by the older order sitting on the book
                execution_price = lowest_ask["price"]
                trade_amount = min(highest_bid["amount"], lowest_ask["amount"])

                buyer = highest_bid["user"]
                seller = lowest_ask["user"]

                # Process transaction logic balances
                total_usd_cost = trade_amount * execution_price
                
                # Mutation updates
                self.users[buyer]["balances"]["USD"] -= total_usd_cost
                self.users[buyer]["balances"]["BTC"] += trade_amount

                self.users[seller]["balances"]["USD"] += total_usd_cost
                self.users[seller]["balances"]["BTC"] -= trade_amount

                # Update remaining order quantities
                highest_bid["amount"] -= trade_amount
                lowest_ask["amount"] -= trade_amount

                print(f"\n🚀 [TRADE MATCHED]: {buyer} bought {trade_amount:.4f} BTC from {seller} at ${execution_price:,.2f} per coin.")
                print(f"    Total Value: ${total_usd_cost:,.2f}")

                # Purge completed or empty orders from structural memory queues
                if highest_bid["amount"] <= 0:
                    self.order_book.buy_orders.pop(0)
                if lowest_ask["amount"] <= 0:
                    self.order_book.sell_orders.pop(0)
            else:
                break # No overlapping prices found, close engine match cycle

    def limit_order(self, username, side, price, amount):
        """Places an intentional limit transaction request into the order books."""
        if username not in self.users:
            print("[-] Invalid User.")
            return

        # Verification checks to stop double-spending or processing insufficient funds
        if side == "BUY":
            required_usd = price * amount
            if self.users[username]["balances"]["USD"] < required_usd:
                print(f"[-] Order Rejected: {username} has insufficient USD balance. Needs: ${required_usd:,.2f}")
                return
        elif side == "SELL":
            if self.users[username]["balances"]["BTC"] < amount:
                print(f"[-] Order Rejected: {username} has insufficient BTC balances.")
                return

        order = self.order_book.add_order(side, username, price, amount)
        print(f"[+] Limit Order Placed: {username} wants to {side} {amount:.4f} BTC at ${price:,.2f}")
        
        # Immediately activate internal balance reconciliation clearing
        self.match_orders()

