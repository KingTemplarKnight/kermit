import os
import sys
import time
import random
import datetime

# ANSI Color Codes for terminal UI visibility
GREEN = "\033[92m"
RED = "\033[91m"
CYAN = "\033[96m"
WHITE = "\033[97m"
RESET = "\033[0m"
BOLD = "\033[1m"

def show_reflection_banner():
    print(f"{CYAN}{BOLD}====================================================")
    print("      SELF-EDITING CODE SEEDING ENGINE v5.0         ")
    print(f"      MODE: PHYSICAL FILE SOURCE REFLECTION ACTIVE ")
    print(f"===================================================={RESET}\n")

# Sandbox text dataset to classify against
MOCK_DATABASE = [
    {"id": 1, "text": "flipper_sub_ghz_antenna_sniff_315mhz", "tag": "FLIPPER"},
    {"id": 2, "text": "redhack_leak_database_credential_dump", "tag": "REDHACK"},
    {"id": 3, "text": "flipper_nfc_rfid_card_cloner_active", "tag": "FLIPPER"},
    {"id": 4, "text": "redhack_manifesto_transparency_loop", "tag": "REDHACK"}
]

class SelfEditingEngine:
    def __init__(self, target_tag="REDHACK"):
        self.target_tag = target_tag
        self.generation = 0
        self.primitives = ["redhack", "leak", "flipper", "sub_ghz", "nfc"]
        # Seed random filtering keywords
        self.population = [[random.choice(self.primitives)] for _ in range(10)]
        self.output_filename = "autonomous_module.py"

    def evaluate_rule(self, rule_keywords):
        """Calculates accuracy mapping rules across the text data pool."""
        true_positives = 0
        false_positives = 0
        total_targets = sum(1 for item in MOCK_DATABASE if item["tag"] == self.target_tag)

        for item in MOCK_DATABASE:
            is_match = any(kw in item["text"] for kw in rule_keywords)
            if is_match:
                if item["tag"] == self.target_tag:
                    true_positives += 1
                else:
                    false_positives += 1

        accuracy = (true_positives / total_targets) * 100.0 if total_targets > 0 else 0.0
        if false_positives > 0: accuracy *= 0.1 # Heavily penalize false matches
        return accuracy

    def write_new_source_code_to_disk(self, optimized_keywords):
        """POLYSYNTHETIC REFLECTION ROUTINE: Automatically writes a complete, 

        functional, standalone Python program directly onto the local hard drive.
        """
        print(f"\n{RED}[!] TARGET MATRIX CONVERGED! INITIALIZING SELF-EDITING SEQUENCE...{RESET}")
        time.sleep(0.5)
        print(f"[*] Compiling dynamic Python source syntax tree in local memory arrays...")
        time.sleep(0.5)

        # Format the evolved keywords into string code components
        formatted_keywords = ", ".join(f"'{k}'" for k in optimized_keywords)

        # This string template forms the entire architecture of the brand-new file
        generated_code_template = f"""# =========================================================
#  AUTONOMOUSLY REFACTORED APPLICATION MODULE
#  GENERATED VIA POLY-PROGRAMMATIC REFLECTION LAYER
#  TIMESTAMP: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}
# =========================================================
import sys

def execute_compiled_filter(raw_string):
    # This explicit string validation logic was self-written by the genetic engine
    target_keywords = [{formatted_keywords}]
    
    match_detected = any(keyword in raw_string.lower() for keyword in target_keywords)
    return "MATCHED_TARGET" if match_detected else "CLEARED"

if __name__ == "__main__":
    print("=== SELF-EXECUTING AUTONOMOUS SCRIPT MODULE RUNNING ===")
    test_input = "redhack_leak_database_credential_dump"
    verdict = execute_compiled_filter(test_input)
    print(f"Testing Stream: '{{test_input}}'")
    print(f"Result Verdict: {{verdict}}")
"""

        # Write the generated code string directly to a physical file on disk
        with open(self.output_filename, "w") as source_file:
            source_file.write(generated_code_template)

        print(f"{GREEN}[+] SUCCESS: New standalone script written to disk: '{self.output_filename}'{RESET}")
        print(f"{GREEN}[+] Code compilation block verified. The script can now run independently.{RESET}\n")
        sys.stdout.write("\a") # Performance complete alert chime
        sys.stdout.flush()

    def run_optimization_lifecycle(self):
        show_reflection_banner()
        print(f"{CYAN}[*] Desired Class Target Allocation: {self.target_tag}{RESET}")
        print(f"{CYAN}[*] Target Destination File Path: ./{self.output_filename}{RESET}\n")
        time.sleep(1.0)

        while True:
            self.generation += 1
            scored_pool = [(self.evaluate_rule(rule), rule) for rule in self.population]
            scored_pool.sort(key=lambda x: x, reverse=True)

            best_accuracy, best_rule = scored_pool
            print(f"{WHITE}[Generation {self.generation:02d}]{RESET} Best Active Rule Accuracy: {GREEN}{best_accuracy:.1f}%{RESET} | Rules: {best_rule}")

            # Stopping Criterion: Accuracy hits 100%. Trigger the code reflection writer!
            if best_accuracy == 100.0:
                self.write_new_source_code_to_disk(best_rule)
                break

            # Replenish the generation matrix using breeding pools
            survivors = [rule for acc, rule in scored_pool[:3]]
            next_gen = list(survivors)
            while len(next_gen) < len(self.population):
                child = list(set(random.choice(survivors) + random.choice(survivors)))
                if random.random() < 0.3:
                    child.append(random.choice(self.primitives))
                next_gen.append(child)
            
            self.population = next_gen
            time.sleep(0.1)

if __name__ == "__main__":
    engine = SelfEditingEngine()
    engine.run_optimization_lifecycle()
