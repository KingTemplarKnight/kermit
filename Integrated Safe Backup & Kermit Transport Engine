import os
import tarfile
import logging
from datetime import datetime
from cryptography.hazmat.primitives.asymmetric import rsa, padding
from cryptography.hazmat.primitives import hashes

# Configure logging baseline
logging.basicConfig(level=logging.INFO, format='%(asctime)s - [%(levelname)s] - %(message)s')

class SecureBackupTransportPipeline:
    """
    Archives local directories, signs them using asymmetric cryptography (RSA),
    and formats the data into safe, sequenced Kermit network communication frames.
    """
    SOH = '\x01'  # Start of Header (Canonical Kermit MARK)

    def __init__(self, source_dir: str, export_vault: str, packet_size: int = 94):
        self.source_dir = source_dir
        self.export_vault = export_vault
        self.packet_size = packet_size
        
        os.makedirs(self.export_vault, exist_ok=True)
        
        # Initialize internal RSA asymmetric keys for automated signing
        logging.info("Generating internal 2048-bit RSA key pair for secure archive verification...")
        self.private_key = rsa.generate_private_key(public_exponent=65537, key_size=2048)
        self.public_key = self.private_key.public_key()

    def generate_signed_archive(self) -> tuple[str, bytes]:
        """Creates a local tarball backup and computes an immutable SHA-256 RSA signature."""
        if not os.path.exists(self.source_dir) or not os.listdir(self.source_dir):
            raise FileNotFoundError("Source directory is empty or missing baseline structures.")

        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        archive_path = os.path.join(self.export_vault, f"backup_{timestamp}.tar.gz")

        # 1. Compress source files
        with tarfile.open(archive_path, "w:gz") as tar:
            tar.add(self.source_dir, arcname=os.path.basename(self.source_dir))
        
        # 2. Compute cryptographic signature over the payload bytes
        with open(archive_path, "rb") as f:
            archive_bytes = f.read()

        signature = self.private_key.sign(
            archive_bytes,
            padding.PSS(mgf=padding.MGF1(hashes.SHA256()), salt_length=padding.PSS.MAX_LENGTH),
            hashes.SHA256()
        )
        
        logging.info(f"Generated secure backup and attached RSA signature: {archive_path}")
        return archive_path, signature

    def verify_archive(self, archive_path: str, signature: bytes) -> bool:
        """Verifies the archive against its signature using the public key."""
        try:
            with open(archive_path, "rb") as f:
                archive_bytes = f.read()

            self.public_key.verify(
                signature,
                archive_bytes,
                padding.PSS(mgf=padding.MGF1(hashes.SHA256()), salt_length=padding.PSS.MAX_LENGTH),
                hashes.SHA256()
            )
            logging.info("Cryptographic Verification SUCCESS: Archive matches signature baseline perfectly.")
            return True
        except Exception as e:
            logging.critical(f"Cryptographic Verification FAILED: Alteration detected! {e}")
            return False

    @staticmethod
    def _to_kermit_char(value: int) -> str:
        """Applies canonical standard printing +32 ASCII protocol character offset."""
        return chr((value & 63) + 32)

    def generate_kermit_stream(self, archive_path: str) -> list[str]:
        """Breaks down the verified binary archive file into sequenced, checksum-validated packets."""
        with open(archive_path, "rb") as f:
            raw_bytes = f.read()

        # Convert raw binary payload to a hex string to remain safe over old 7-bit/8-bit serial lines
        safe_ascii_payload = raw_bytes.hex().upper()
        
        payload_chunk_size = self.packet_size - 5  # Leave space for SOH, LEN, SEQ, TYPE, and CHECKSUM
        packet_stream = []
        sequence_id = 1

        for i in range(0, len(safe_ascii_payload), payload_chunk_size):
            chunk = safe_ascii_payload[i:i + payload_chunk_size]
            
            # Format fields using protocol specifications
            len_char = self._to_kermit_char(len(chunk) + 3)
            seq_char = self._to_kermit_char(sequence_id)
            type_char = 'D'  # Standard Kermit token data indicator
            
            packet_body = f"{len_char}{seq_char}{type_char}{chunk}"
            
            # Formulate 1-byte modular block arithmetic checksum
            checksum_val = sum(ord(c) for c in packet_body) & 0x3F
            checksum_char = self._to_kermit_char(checksum_val)
            
            full_packet = f"{self.SOH}{packet_body}{checksum_char}"
            packet_stream.append(full_packet)
            sequence_id = (sequence_id + 1) % 64  # Standard Kermit wraps sequence identifiers at 63

        logging.info(f"Successfully serialized backup stream into {len(packet_stream)} transmission packets.")
        return packet_stream

# --- Execution Entry Routine ---
if __name__ == "__main__":
    # Define local file environments
    SOURCE_DIRECTORY = "./project_live_data"
    VAULT_DIRECTORY = "./secure_backup_vault"

    # Pre-populate directory with simulated project operational assets
    os.makedirs(SOURCE_DIRECTORY, exist_ok=True)
    with open(os.path.join(SOURCE_DIRECTORY, "app_manifest.json"), "w") as f:
        f.write('{"version": "1.4.2", "status": "verified_baseline"}')

    # Execute complete defensive deployment routine
    pipeline = SecureBackupTransportPipeline(SOURCE_DIRECTORY, VAULT_DIRECTORY)
    
    # 1. Archive & Cryptographically Sign
    archive, rsa_sig = pipeline.generate_signed_archive()
    
    # 2. Run Verification Audit Block
    if pipeline.verify_archive(archive, rsa_sig):
        # 3. Format into structured communication packets
        network_packets = pipeline.generate_kermit_stream(archive)
        
        print("\n--- Network Packet Pipeline Preview (First 3 Frame Vectors) ---")
        for idx, packet in enumerate(network_packets[:3]):
            print(f"Packet [{idx + 1}]: {repr(packet)}")
