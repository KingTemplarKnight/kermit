class EvolvingClassifier:
    def __init__(self, pool_size=15):
        self.pool_size = pool_size
        # Genetic primitives used to build string matching rules
        self.rule_primitives = ["flipper", "nfc", "sub_ghz", "redhack", "leak", "http", "dns", "badusb"]
        self.reboot_classifier(CLASSIFIER_STATE["target_category"])

    def reboot_classifier(self, target_cat):
        """Wipes active rules and re-seeds random filters for the new target classification."""
        self.target_category = target_cat
        self.generation = 0
        # Population consists of string mutation keywords
        self.population = [[random.choice(self.rule_primitives)] for _ in range(self.pool_size)]
        with lock:
            CLASSIFIER_STATE["target_category"] = self.target_category
            CLASSIFIER_STATE["generation"] = 0
            CLASSIFIER_STATE["accuracy_percentage"] = 0.0
            CLASSIFIER_STATE["complete"] = False
            CLASSIFIER_STATE["reset_trigger"] = False

    def evaluate_rule_accuracy(self, rule_keywords):
        """Measures classification accuracy against the target dataset."""
        true_positives = 0
        false_positives = 0
        total_targets = sum(1 for item in RAW_DATA_STREAM if item["type"] == self.target_category)

        for item in RAW_DATA_STREAM:
            # A record matches if any keyword in the rule exists in its payload text
            is_match = any(kw in item["payload"] for kw in rule_keywords)
            
            if is_match:
                if item["type"] == self.target_category:
                    true_positives += 1
                else:
                    false_positives += 1

        # Penalize rules that trigger false alarms on the wrong data types
        score = true_positives - (false_positives * 2)
        # Calculate percentage matching accuracy
        accuracy = (true_positives / total_targets) * 100.0 if total_targets > 0 else 0.0
        if false_positives > 0:
            accuracy *= 0.5 # Deduct heavily for misclassifications
        return max(score, -100), max(accuracy, 0.0), true_positives

    def run_training_step(self):
        if CLASSIFIER_STATE["reset_trigger"]:
            self.reboot_classifier(CLASSIFIER_STATE["target_category"])
            return

        self.generation += 1
        scored_pool = []
        
        for rule in self.population:
            score, accuracy, tp = self.evaluate_rule_accuracy(rule)
            scored_pool.append((score, accuracy, tp, rule))
            
        # Sort descending: Highest matching accuracy floats to the top
        scored_pool.sort(key=lambda x: x[0], reverse=True)
        best_score, best_accuracy, best_tp, best_rule = scored_pool[0]
        
        rule_string = " OR ".join(f"'{k}'" for k in best_rule)
        with lock:
            CLASSIFIER_STATE["generation"] = self.generation
            CLASSIFIER_STATE["active_filter_rule"] = f"IF payload contains ({rule_string})"
            CLASSIFIER_STATE["accuracy_percentage"] = round(best_accuracy, 2)
            CLASSIFIER_STATE["records_isolated"] = best_tp
            CLASSIFIER_STATE["complete"] = (best_accuracy == 100.0)

        if CLASSIFIER_STATE["complete"]:
            time.sleep(0.1)
            return

        # Breed the top performing rules to build advanced compound criteria
        survivors = [rule for score, acc, tp, rule in scored_pool[:4]]
        next_gen = list(survivors)
        
        while len(next_gen) < self.pool_size:
            p1, p2 = random.choice(survivors), random.choice(survivors)
            # Recombination
            child = list(set(p1 + p2))
            # Apply a mutation: Either add a structural primitive keyword or prune the array size
            if random.random() < 0.4:
                if random.choice([True, False]) or len(child) == 1:
                    child.append(random.choice(self.rule_primitives))
                else:
                    child.pop(random.randint(0, len(child) - 1))
            next_gen.append(child)
            
        self.population = next_gen

# --- DUAL-THREAD WEB APPLICATION CONDUIT ---
class ClassifierWebHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/api/classifier_data':
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            with lock:
                self.wfile.write(json.dumps(CLASSIFIER_STATE).encode())
        elif self.path == '/' or self.path == '/index.html':
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            self.wfile.write(CLASSIFIER_UI_HTML.encode())
        else:
            self.send_error(404, "Not Found")

    def do_POST(self):
        if self.path == '/api/set_category':
            length = int(self.headers['Content-Length'])
            post_data = self.rfile.read(length).decode('utf-8')
            params = urllib.parse.parse_qs(post_data)
            
            if 'category' in params:
                new_cat = params['category'][0]
                with lock:
                    CLASSIFIER_STATE["target_category"] = new_cat
                    CLASSIFIER_STATE["reset_trigger"] = True
                self.send_response(200)
                self.end_headers()
                return
        self.send_error(400, "Bad POST request")

def start_web_infrastructure(port=8080):
    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer(("", port), ClassifierWebHandler) as httpd:
        print(f"[*] Intelligent Classifier UI live at: http://localhost:{port}")
        httpd.serve_forever()

