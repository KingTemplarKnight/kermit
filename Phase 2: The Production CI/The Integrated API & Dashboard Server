import sys
import time
import json
import sqlite3
import http.server
import socketserver
import threading

DB_FILENAME = "ingested_records.db"

class DashboardMetricsEngine:
    @staticmethod
    def get_live_metrics():
        """Queries the SQL database file to compile active ingestion statistics."""
        try:
            conn = sqlite3.connect(DB_FILENAME)
            cursor = conn.cursor()
            
            # 1. Calculate total rows indexed
            cursor.execute("SELECT COUNT(*) FROM system_telemetry")
            total_records = cursor.fetchone()[0]
            
            # 2. Group and aggregate row volumes by Country Node
            cursor.execute("""
                SELECT country_code, COUNT(*) as count 
                FROM system_telemetry 
                GROUP BY country_code 
                ORDER BY count DESC 
                LIMIT 5
            """)
            distribution = {row[0]: row[1] for row in cursor.fetchall()}
            
            # 3. Pull the latest 3 records added to the log stream
            cursor.execute("""
                SELECT id, timestamp, country_code, latitude, longitude 
                FROM system_telemetry 
                ORDER BY id DESC 
                LIMIT 3
            """)
            latest_rows = [{
                "id": r[0], "timestamp": r[1], "country": r[2], "coords": f"[{r[3]}, {r[4]}]"
            } for r in cursor.fetchall()]
            
            conn.close()
            return {
                "status": "active",
                "total_records": total_records,
                "distribution": distribution,
                "latest_records": latest_rows
            }
        except sqlite3.OperationalError:
            return {"status": "initializing", "total_records": 0, "distribution": {}, "latest_records": []}

# --- MULTI-THREADED NETWORK ROUTING INTERFACE ---
class DashboardHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/api/metrics':
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            metrics_payload = DashboardMetricsEngine.get_live_metrics()
            self.wfile.write(json.dumps(metrics_payload).encode('utf-8'))
        elif self.path == '/' or self.path == '/index.html':
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            self.wfile.write(DASHBOARD_HTML_INTERFACE.encode('utf-8'))
        else:
            self.send_error(404, "Endpoint Unmapped")

def start_ui_server(port=8080):
    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer(("", port), DashboardHandler) as httpd:
        print(f"[*] Live Analytics Dashboard actively broadcasting at: http://localhost:{port}")
        httpd.serve_forever()

