apiVersion: v1
kind: Namespace
metadata:
  name: zerocool-secops
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: auth-log-pvc
  namespace: zerocool-secops
spec:
  accessModes:
    - ReadWriteMany
  resources:
    requests:
      storage: 2Gi
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: zerocool-threat-core-deployment
  namespace: zerocool-mesh
  labels:
    app: threat-intel-core
spec:
  replicas: 3 # Automatically balances and scales the workload across 3 parallel instances
  selector:
    matchLabels:
      app: threat-intel-core
  template:
    metadata:
      labels:
        app: threat-intel-core
    spec:
      containers:
      - name: security-engine
        image: yourregistry/zerocool-secops:v8.5
        ports:
        - containerPort: 8080
        env:
        - name: SLACK_WEBHOOK_URL
          valueFrom:
            secretKeyRef:
              name: secops-channel-secrets
              key: slack-url
        - name: DISCORD_WEBHOOK_URL
          valueFrom:
            secretKeyRef:
              name: secops-channel-secrets
              key: discord-url
        volumeMounts:
        - name: shared-log-volume
          mountPath: /app
        resources:
          limits:
            cpu: "500m"
            memory: "512Mi"
          requests:
            cpu: "250m"
            memory: "256Mi"
      volumes:
      - name: shared-log-volume
        persistentVolumeClaim:
          claimName: auth-log-pvc
---
apiVersion: v1
kind: Service
metadata:
  name: zerocool-dashboard-service
  namespace: zerocool-secops
spec:
  selector:
    app: threat-intel-core
  ports:
    - protocol: TCP
      port: 80
      targetPort: 8080
  type: LoadBalancer
