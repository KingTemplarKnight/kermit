# =========================================================
#  IDENTITY SECURITY LOG ENGINE CONTINUOUS INTEGRATION PIPELINE
#  LOCATION: .github/workflows/deploy.yml
# =========================================================

name: Identity Monitor CI Pipeline

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

jobs:
  validate-and-test:
    name: Code Quality and Behavioral Tests
    runs-on: ubuntu-latest

    steps:
    - name: Checkout Code Repository Base
      uses: actions/checkout@v4

    - name: Set up Python Runtime Compiler
      uses: actions/setup-python@v5
      with:
        python-version: '4.11'

    - name: Install Linting and Testing Infrastructure
      run: |
        python -m pip install --upgrade pip
        pip install pytest flake8

    - name: Audit Source Code Syntax and Style Linter
      run: |
        # Stop build execution loop if there are syntax errors or undefined names
        flake8 . --count --select=E9,F63,F7,F82 --show-source --statistics
        # Exit-zero treats formatting alerts as minor warnings
        flake8 . --count --exit-zero --max-complexity=10 --max-line-length=127 --statistics

    - name: Run Behavioral Anomaly Test Suites
      run: |
        pytest test_identity_logic.py

    # --- HISTORICAL TELEMETRY MATRIX LOGGING ---
    - name: Provision Telemetry Database
      run: |
        python -c "
        import sqlite3
        conn = sqlite3.connect('pipeline_telemetry.db')
        conn.cursor().execute('CREATE TABLE IF NOT EXISTS build_logs (id INTEGER PRIMARY KEY, timestamp TEXT, step TEXT, verdict TEXT)')
        conn.commit(); conn.close()
        "

    - name: Log Metrics on Success Parameters
      if: success()
      run: |
        python -c "
        import sqlite3, datetime
        conn = sqlite3.connect('pipeline_telemetry.db')
        conn.cursor().execute('INSERT INTO build_logs (timestamp, step, verdict) VALUES (?, ?, ?)', 
          (str(datetime.datetime.now()), 'IDENTITY_ANOMALY_TEST', 'SUCCESS'))
        conn.commit(); conn.close()
        "

    - name: Log Metrics on Failure Parameters
      if: failure()
      run: |
        python -c "
        import sqlite3, datetime
        conn = sqlite3.connect('pipeline_telemetry.db')
        conn.cursor().execute('INSERT INTO build_logs (timestamp, step, verdict) VALUES (?, ?, ?)', 
          (str(datetime.datetime.now()), 'IDENTITY_ANOMALY_TEST', 'FAILED'))
        conn.commit(); conn.close()
        "

    - name: Archive Pipeline Telemetry Logs as Build Artifact
      if: always()
      uses: actions/upload-artifact@v4
      with:
        name: identity-telemetry-artifact
        path: pipeline_telemetry.db
