import sys
import time
import json
import os
import http.server
import socketserver
import datetime

LOG_FILENAME = "auth_stream.log"
THREAT_FILENAME = "detected_threats.json"

class OpsMetricsEngine:
    @staticmethod
    def get_live_telemetry():
        """Performs live reconnaissance on active log files to compile security metrics."""
        total_logs_scanned = 0
        active_users = set()
        
        # 1. Scan the raw authentication log stream for volume metrics
        if os.path.exists(LOG_FILENAME):
            try:
                with open(LOG_FILENAME, "r") as f:
                    for line in f:
                        if line.strip() and "|" in line:
                            total_logs_scanned += 1
                            parts = line.split("|")
                            if len(parts) > 1:
                                active_users.add(parts[1].strip())
            except Exception:
                pass

        # 2. Extract resolved threat alerts out of physical JSON storage
        alerts_list = []
        if os.path.exists(THREAT_FILENAME):
            try:
                with open(THREAT_FILENAME, "r") as f:
                    alerts_list = json.load(f)
            except Exception:
                pass

        return {
            "status": "operational",
            "timestamp": datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "total_logs_scanned": total_logs_scanned,
            "unique_users_tracked": len(active_users),
            "total_threats_blocked": len(alerts_list),
            "recent_alerts": alerts_list[-4:] # Pull the latest 4 anomalies
        }

# --- MULTI-THREADED NETWORK ROUTING INTERFACE ---
class OpsDashboardHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/api/ops_metrics':
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            payload = OpsMetricsEngine.get_live_telemetry()
            self.wfile.write(json.dumps(payload).encode('utf-8'))
        elif self.path == '/' or self.path == '/index.html':
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            self.wfile.write(OPS_DASHBOARD_HTML.encode('utf-8'))
        else:
            self.send_error(404, "Endpoint Unmapped")

def start_ops_server(port=8080):
    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer(("", port), OpsDashboardHandler) as httpd:
        print(f"[*] Live Operations Dashboard actively broadcasting at: http://localhost:{port}")
        httpd.serve_forever()

