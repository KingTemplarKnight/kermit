import os
import sys
import time
import json
import datetime

# ANSI Color Codes for scannability
ORANGE = "\033[38;5;208m"
GREEN = "\033[92m"
RED = "\033[91m"
YELLOW = "\033[93m"
CYAN = "\033[96m"
RESET = "\033[0m"

class LiveLogAuditor:
    def __init__(self):
        self.input_file = "auth_stream.log"
        self.output_file = "detected_threats.json"
        self.user_history = {}
        self.alerts = []

    def parse_log_line(self, line):
        """Processes a single raw log string, extracting operational components."""
        try:
            parts = [p.strip() for p in line.split("|")]
            if len(parts) < 5:
                return None
            return {
                "timestamp": datetime.datetime.strptime(parts[0], "%Y-%m-%d %H:%M:%S"),
                "user": parts[1],
                "event": parts[2],
                "ip": parts[3],
                "location": parts[4]
            }
        except Exception:
            return None

    def analyze_behavior(self, current_log):
        """Heuristic rule-engine checking for Impossible Travel and MFA Fatigue spikes."""
        user = current_log["user"]
        loc = current_log["location"]
        ts = current_log["timestamp"]
        event = current_log["event"]
        
        if user not in self.user_history:
            self.user_history[user] = []
            
        for past in self.user_history[user]:
            # Anomaly Detection 1: Impossible Travel Check
            if past["location"] != loc:
                time_delta = abs((ts - past["timestamp"]).total_seconds()) / 60.0
                if time_delta < 60.0: # Traveling between separate countries in under an hour
                    print(f"  {RED}[CRITICAL ALERT] Impossible Travel Velocity: {user} ({past['location']} -> {loc} in {int(time_delta)} mins){RESET}")
                    self.alerts.append({
                        "anomaly": "IMPOSSIBLE_TRAVEL", "user": user,
                        "details": f"Moved from {past['location']} to {loc} in {int(time_delta)} minutes.",
                        "timestamp": str(datetime.datetime.now())
                    })
            
            # Anomaly Detection 2: MFA Fatigue Spike Check
            if event == "MFA_PROMPT_APPROVED" and past["event"] == "MFA_PROMPT_DENIED":
                time_delta_sec = abs((ts - past["timestamp"]).total_seconds())
                if time_delta_sec < 45.0: # Success instantly following a rapid rejection window
                    print(f"  {YELLOW}[WARNING] Potential MFA Push Fatigue / Spamming Loop: {user} approved inside {int(time_delta_sec)} seconds.{RESET}")
                    self.alerts.append({
                        "anomaly": "MFA_PUSH_FATIGUE", "user": user,
                        "details": f"Approval secured after push spamming inside {int(time_delta_sec)} seconds.",
                        "timestamp": str(datetime.datetime.now())
                    })

        self.user_history[user].append(current_log)
        
        # Commit detected threat events straight back to physical JSON storage
        with open(self.output_file, "w") as f:
            json.dump(self.alerts, f, indent=4)

    def start_monitoring_service(self):
        print(f"{CYAN}====================================================")
        print("        ZEROCOOL ID-IDENTITY LOG SCANNER ACTIVE      ")
        print(f"        MONITORING TARGET FILE: ./{self.input_file}")
        print(f"===================================================={RESET}\n")
        
        if not os.path.exists(self.input_file):
            with open(self.input_file, "w") as f: f.write("") # Touch file if empty

        with open(self.input_file, "r") as f:
            # Move read pointer to the current end of file to simulate persistent log tailing
            f.seek(0, os.SEEK_END)
            
            while True:
                line = f.readline()
                if not line:
                    time.sleep(1.0) # Rest thread briefly to preserve compute allocation limits
                    continue
                    
                log_data = self.parse_log_line(line)
                if log_data:
                    print(f"{ORANGE}[*] Parsing log line for entity: {log_data['user']}...{RESET}")
                    self.analyze_behavior(log_data)

if __name__ == "__main__":
    auditor = LiveLogAuditor()
    auditor.start_monitoring_service()
