# ANSI Color Codes for scannability
GREEN = "\033[92m"
RED = "\033[91m"
YELLOW = "\033[93m"
CYAN = "\033[96m"
RESET = "\033[0m"

class RogueAssetAuditor:
    def __init__(self, subnet="192.168.1"):
        self.subnet = subnet
        self.known_inventory = ["192.168.1.1", "192.168.1.50"] # Authorized baseline
        self.critical_ports = [21, 22, 23, 445, 3389] # Ports commonly targeted for initial access

    def grab_service_banner(self, ip, port):
        """Safely inspects an open socket to read version banners for asset management."""
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.settimeout(0.3)
                s.connect((ip, port))
                if port == 80:
                    s.sendall(b"HEAD / HTTP/1.0\r\n\r\n")
                banner = s.recv(256).decode('utf-8', errors='ignore').strip()
                return banner if banner else "TCP Port Open (No Banner Broadcasted)"
        except Exception:
            return None

    def execute_audit_sweep(self):
        print(f"{CYAN}[*] Starting internal network baseline audit on subnet {self.subnet}.X...{RESET}")
        
        for host in range(1, 10): # Controlled testing range
            target_ip = f"{self.subnet}.{host}"
            
            for port in self.critical_ports:
                banner = self.grab_service_banner(target_ip, port)
                if banner:
                    if target_ip not in self.known_inventory:
                        print(f"{RED}[CRITICAL ALERT] Rogue Asset Found: {target_ip} (Port {port}){RESET}")
                        print(f"  Banner Data: {banner}")
                        print(f"  Action Required: Isolate host via VLAN control rules immediately.")
                    else:
                        print(f"{GREEN}[PASS] Authorized Host Confirmed: {target_ip} on port {port}{RESET}")

if __name__ == "__main__":
    auditor = RogueAssetAuditor()
    auditor.execute_audit_sweep()
