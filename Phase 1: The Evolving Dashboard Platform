# Global storage for the UI to read
LATEST_TELEMETRY = {
    "generation": 0,
    "expression": "Initializing...",
    "length": 0,
    "output": 0.0,
    "target": 0.0,
    "complete": False
}

class GeneticMathCore:
    def __init__(self, target_value=27.5, pool_size=20):
        self.target_value = target_value
        self.pool_size = pool_size
        self.generation = 0
        self.allowed_operators = ['+', '-', '*', '/', '**', 'math.sqrt']
        self.population = [self.generate_random_formula() for _ in range(self.pool_size)]
        LATEST_TELEMETRY["target"] = target_value

    def generate_random_formula(self):
        if random.choice([True, False]):
            return [str(random.randint(1, 50)), random.choice(['+', '-', '*', '/']), str(random.randint(1, 50))]
        return ["math.sqrt(", str(random.randint(1, 1000)), ")"]

    def evaluate_expression(self, tokens):
        expr_str = "".join(tokens)
        try:
            result = eval(expr_str, {"math": math})
            if isinstance(result, complex) or math.isnan(result) or math.isinf(result):
                return 0.0, expr_str
            return float(result), expr_str
        except Exception:
            return 0.0, expr_str

    def measure_fitness(self, tokens):
        result, expr_str = self.evaluate_expression(tokens)
        distance = abs(self.target_value - result)
        base = 2000.0 if distance == 0 else 1.0 / (distance + 0.001)
        return max(base - (len(expr_str) * 0.05), 0.001)

    def evolve(self):
        global LATEST_TELEMETRY
        self.generation += 1
        
        scored_pool = [(self.measure_fitness(ind), ind) for ind in self.population]
        scored_pool.sort(key=lambda x: x[0], reverse=True)
        
        best_score, best_formula = scored_pool[0]
        actual_value, expr_str = self.evaluate_expression(best_formula)
        
        # Update the live data structure shared with the web server
        LATEST_TELEMETRY = {
            "generation": self.generation,
            "expression": expr_str,
            "length": len(expr_str),
            "output": round(actual_value, 4),
            "target": self.target_value,
            "complete": (actual_value == self.target_value)
        }
        
        if LATEST_TELEMETRY["complete"]:
            return True
            
        survivors = [ind for score, ind in scored_pool[:max(2, int(self.pool_size * 0.25))]]
        next_gen = list(survivors)
        
        while len(next_gen) < self.pool_size:
            p1, p2 = random.choice(survivors), random.choice(survivors)
            child = p1[:random.randint(0, len(p1))] + p2[random.randint(0, len(p2)):]
            if not child: child = self.generate_random_formula()
            
            # Mutation Layer
            if random.random() < 0.3:
                idx = random.randint(0, len(child) - 1)
                child[idx] = random.choice(['+', '-', '*', '/', '2', '5', 'math.sqrt('])
            next_gen.append(child)
            
        self.population = next_gen
        return False

# --- LIVE DASHBOARD NETWORK SERVER ---
class DashboardHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/api/telemetry':
            # Send live engine data as a JSON endpoint
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            self.wfile.write(json.dumps(LATEST_TELEMETRY).encode())
        elif self.path == '/' or self.path == '/index.html':
            # Serve the visualization UI frontend dashboard code
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            self.wfile.write(DASHBOARD_UI_HTML.encode())
        else:
            self.send_error(404, "File Not Found")

def start_web_server(port=8080):
    handler = DashboardHandler
    # Allow instant address reuse during restarts
    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer(("", port), handler) as httpd:
        print(f"[*] Live Dashboard Server actively broadcasting at: http://localhost:{port}")
        httpd.serve_forever()

