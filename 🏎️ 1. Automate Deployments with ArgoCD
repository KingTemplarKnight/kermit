apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: blocklang-pipeline-engine
  namespace: argocd
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: 'https://github.com'
    targetRevision: HEAD
    path: k8s
  destination:
    server: 'https://default.svc'
    namespace: blocklang-pipeline
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - ApplyOutOfSyncOnly=true
