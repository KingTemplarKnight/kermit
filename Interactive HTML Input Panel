# Thread-safe global telemetry state container
ENGINE_STATE = {
    "generation": 0,
    "expression": "Initializing infrastructure layers...",
    "length": 0,
    "output": 0.0,
    "target": 50.0, # Initial fallback destination target metric
    "complete": False,
    "reset_flag": False
}

lock = threading.Lock()

class GeneticMathCore:
    def __init__(self, pool_size=25):
        self.pool_size = pool_size
        self.allowed_operators = ['+', '-', '*', '/', '**', 'math.sqrt']
        self.reset_engine(ENGINE_STATE["target"])

    def reset_engine(self, new_target):
        """Wipes active population and re-allocates arrays targeting a fresh vector entry."""
        self.target_value = float(new_target)
        self.generation = 0
        self.population = [self.generate_random_formula() for _ in range(self.pool_size)]
        with lock:
            ENGINE_STATE["target"] = self.target_value
            ENGINE_STATE["generation"] = 0
            ENGINE_STATE["complete"] = False
            ENGINE_STATE["reset_flag"] = False

    def generate_random_formula(self):
        if random.choice([True, False]):
            return [str(random.randint(1, 100)), random.choice(['+', '-', '*', '/']), str(random.randint(1, 100))]
        return ["math.sqrt(", str(random.randint(1, 2000)), ")"]

    def evaluate_expression(self, tokens):
        expr_str = "".join(tokens)
        try:
            result = eval(expr_str, {"math": math})
            if isinstance(result, complex) or math.isnan(result) or math.isinf(result):
                return 0.0, expr_str
            return float(result), expr_str
        except Exception:
            return 0.0, expr_str

    def measure_fitness(self, tokens):
        result, expr_str = self.evaluate_expression(tokens)
        distance = abs(self.target_value - result)
        base = 3000.0 if distance == 0 else 1.0 / (distance + 0.001)
        return max(base - (len(expr_str) * 0.08), 0.001)

    def evolve_cycle(self):
        """Executes a single step of natural selection, tracking memory adjustments safety rules."""
        # Dynamic check if the UI sent a modification trigger directive
        if ENGINE_STATE["reset_flag"]:
            self.reset_engine(ENGINE_STATE["target"])
            return

        self.generation += 1
        
        scored_pool = [(self.measure_fitness(ind), ind) for ind in self.population]
        scored_pool.sort(key=lambda x: x, reverse=True)
        
        best_score, best_formula = scored_pool
        actual_value, expr_str = self.evaluate_expression(best_formula)
        
        with lock:
            ENGINE_STATE["generation"] = self.generation
            ENGINE_STATE["expression"] = expr_str
            ENGINE_STATE["length"] = len(expr_str)
            ENGINE_STATE["output"] = round(actual_value, 4)
            ENGINE_STATE["complete"] = (abs(actual_value - self.target_value) < 0.0001)
            
        if ENGINE_STATE["complete"]:
            time.sleep(0.1) # Idle CPU throttling buffer once task goals are secured
            return
            
        survivors = [ind for score, ind in scored_pool[:max(2, int(self.pool_size * 0.25))]]
        next_gen = list(survivors)
        
        while len(next_gen) < self.pool_size:
            p1, p2 = random.choice(survivors), random.choice(survivors)
            child = p1[:random.randint(0, len(p1))] + p2[random.randint(0, len(p2)):]
            if not child: child = self.generate_random_formula()
            
            if random.random() < 0.35:
                idx = random.randint(0, len(child) - 1)
                child[idx] = random.choice(['+', '-', '*', '/', '3', '7', 'math.sqrt('])
            next_gen.append(child)
            
        self.population = next_gen

# --- MULTI-THREADED NETWORK DATA CONDUIT ---
class InteractiveDashboardHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/api/telemetry':
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            with lock:
                self.wfile.write(json.dumps(ENGINE_STATE).encode())
        elif self.path == '/' or self.path == '/index.html':
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            self.wfile.write(INTERACTIVE_UI_HTML.encode())
        else:
            self.send_error(404, "Endpoint Unmapped")

    def do_POST(self):
        """Processes parameter mutation instructions pushed directly from the browser window UI."""
        if self.path == '/api/update_target':
            content_length = int(self.headers['Content-Length'])
            post_data = self.rfile.read(content_length).decode('utf-8')
            params = urllib.parse.parse_qs(post_data)
            
            if 'target' in params:
                new_val = float(params['target'][0])
                with lock:
                    ENGINE_STATE["target"] = new_val
                    ENGINE_STATE["reset_flag"] = True # Set the modification flag for processing
                    
                self.send_response(200)
                self.send_header('Content-Type', 'application/json')
                self.end_headers()
                self.wfile.write(json.dumps({"status": "acknowledged", "new_target": new_val}).encode())
                return
        self.send_error(400, "Bad Parameters")

def launch_web_network(port=8080):
    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer(("", port), InteractiveDashboardHandler) as httpd:
        print(f"[*] Interactive Dashboard Live on: http://localhost:{port}")
        httpd.serve_forever()

