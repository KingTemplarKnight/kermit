import sys
import time
import random
import datetime
import hashlib
import json

# ANSI Color Codes for the Flipper Orange LCD theme
ORANGE = "\033[38;5;208m"
GREEN = "\033[92m"
RED = "\033[91m"
CYAN = "\033[96m"
RESET = "\033[0m"
BOLD = "\033[1m"

def network_kermit_avatar():
    return f"""{ORANGE}{BOLD}
    ====================================================================
     _....._        [ PROTOCOL: DECENTRALIZED WEB3 INTELLIGENCE LOOP ]
   .'       '.      [ ATTACK ROUTER: ATTACKCHAINPROXY ENCRYPTED ]
  /  X   X    \\     [ LEDGER STATE: RECURSIVE CHAIN REPLICATION ]

 |   (o) (o)   |    🐸 DECENTRALIZED FLIPPER CORE ON-LINE 🐸
 |     _._     |    
  \\   '---'   /     "Chaining intelligence blocks. Routing past firewall limits."
   '._______.'      
    ===================================================================={RESET}"""

class DecentralizedTacticalAgent:
    def __init__(self):
        self.captured_signals = ["sub_ghz_garage_315mhz", "nfc_amiibo_dump"]
        self.op_cycle = 0
        self.blockchain = []
        self.ledger_filename = "blockchain_ledger.json"
        
        # Initialize the ledger with a Genesis Block
        self.create_block(proof=100, previous_hash="0" * 64, data="GENESIS_BLOCK_INITIALIZED")

    def calculate_hash(self, block):
        """Generates a real SHA-256 hash of a blockchain block."""
        encoded_block = json.dumps(block, sort_keys=True).encode()
        return hashlib.sha256(encoded_block).hexdigest()

    def create_block(self, proof, previous_hash, data):
        """Appends a cryptographically signed block to the simulated ledger."""
        block = {
            'index': len(self.blockchain) + 1,
            'timestamp': str(datetime.datetime.now()),
            'proof': proof,
            'previous_hash': previous_hash,
            'payload': data
        }
        block['hash'] = self.calculate_hash(block)
        self.blockchain.append(block)
        
        # Write updated blockchain state to a local JSON file
        with open(self.ledger_filename, "w") as f:
            json.dump(self.blockchain, f, indent=4)
        return block

    def run_attack_chain_proxy(self):
        """Simulates dynamic network layer configuration via AttackChainProxy nodes."""
        print(f"{CYAN}[*] Activating AttackChainProxy multi-layered routing structure...{RESET}")
        time.sleep(0.4)
        
        proxy_layers = [
            "Local_Socks5_Tunnel_127.0.0.1:9050",
            "AttackChainProxy_Node_Alpha_FR",
            "Encrypted_Onion_Relay_Layer_3",
            "Tor_Exit_Node_Unaligned_Zone"
        ]
        
        for index, node in enumerate(proxy_layers):
            sys.stdout.write(f"\r    {CYAN}[PROXY STACK {index+1}/4]{RESET} Tunneling through: {node}...")
            sys.stdout.flush()
            time.sleep(0.25)
        print(f"\n{GREEN}[+] Proxy connection established. Operational footprint masked successfully.{RESET}\n")

    def run_subghz_and_blockchain_sync(self):
        """Simulates harvesting signals and recording them directly onto the immutable ledger."""
        flipper_hardware_modules = [
            "125kHz_RFID_prox_card_clone", "Sub-GHz_smart_parking_gate_replay",
            "BadUSB_hid_payload_injection", "NFC_hotel_keycard_emulation",
            "Infrared_brute_force_ac_controller", "Autonomous_Smart_Contract_Scrape"
        ]
        
        target_signal = random.choice(flipper_hardware_modules)
        
        if target_signal not in self.captured_signals:
            msg_ingest = f"SIGNAL INTERCEPTED: {target_signal.upper()}"
            print(f"{RED}[!] {msg_ingest}{RESET}")
            
            self.captured_signals.append(target_signal)
            
            # Formulate the block transaction details
            prev_hash = self.blockchain[-1]['hash']
            proof = random.randint(1000, 9999)
            new_block = self.create_block(proof, prev_hash, data=target_signal)
            
            # Sound chime on local storage validation
            sys.stdout.write("\a")
            sys.stdout.flush()
            
            print(f"{GREEN}[+] BLOCK {new_block['index']} VERIFIED & BROADCASTED TO LEDGER{RESET}")
            print(f"    {ORANGE}Hash: {new_block['hash'][:32]}...{RESET}")
            print(f"    {ORANGE}Saved to distributed database repository: {self.ledger_filename}{RESET}")
        else:
            print(f"{ORANGE}[*] DUPLICATE DETECTED: Signal '{target_signal}' matches existing ledger hash. Skipping block creation.{RESET}")

    def start_loop(self):
        """Main automated framework execution loop."""
        print(network_kermit_avatar())
        self.run_attack_chain_proxy()
        
        print(f"{ORANGE}[!] Running decentralized unaligned Flipper Zero framework...{RESET}")
        print(f"{ORANGE}[!] Ledger transactions are appending continuously to: {self.ledger_filename}{RESET}")
        print(f"{RED}[!] Safe Network Abort: Use Ctrl+C to disconnect proxy layers and flush node memory.{RESET}\n")
        time.sleep(1.5)
        
        while True:
            try:
                self.op_cycle += 1
                print(f"{ORANGE}[~] Cycle {self.op_cycle} --- Auditing proxy state nodes...{RESET}")
                if self.op_cycle % 3 == 0:
                    self.run_attack_chain_proxy()  # Rotate proxy configurations periodically
                
                self.run_subghz_and_blockchain_sync()
                print(f"{ORANGE}[~] Flipper Screen: Memory Synchronized. Next data-ingestion sweep queued.{RESET}\n")
                time.sleep(2.0)
            except KeyboardInterrupt:
                print(f"\n\n{RED}[!] DISCONNECTING ATTACKCHAINPROXY: Tunnels flushed successfully.{RESET}")
                print(f"{ORANGE}[!] Immutable validation chain saved cleanly to local file '{self.ledger_filename}'.{RESET}")
                break

if __name__ == "__main__":
    agent = DecentralizedTacticalAgent()
    agent.start_loop()
