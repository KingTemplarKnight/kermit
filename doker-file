# Stage 1: Build C++ and Go native platform binaries
FROM library/golang:1.21 AS go-builder
WORKDIR /build
# Simulate compiling native Go proxies
RUN echo 'package main; func main() { print("Go Network Engine Active") }' > main.go && go build -o go_proxy main.go

# Stage 2: Final integrated multilingual secure runtime container
FROM python:3.11-slim
WORKDIR /app

# Install Node.js, OpenJDK Java, C++ standard libraries, and system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs \
    npm \
    openjdk-17-jr-headless \
    libstdc++6 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy compiled native binaries out of the previous builder stage
COPY --from=go-builder /build/go_proxy /usr/local/bin/go_proxy

# Copy Python requirements and configuration assets
COPY zerocool_api_complete.py .
ENV GITHUB_TOKEN=""

EXPOSE 5000
CMD ["python", "zerocool_api_complete.py"]
