import sys
import time
import datetime
import json
import random
import logging
import sqlite3
import urllib.request

# Configure structural system logging output
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] (%(threadName)s) %(message)s',
    handlers=[logging.StreamHandler(sys.stdout)]
)

class ProductionIngestionEngine:
    def __init__(self, db_filename="ingested_records.db"):
        self.db_filename = db_filename
        self.is_running = False
        self.processed_count = 0
        
        # Initialize relational database layers
        self.init_database_schema()

    def init_database_schema(self):
        """Creates the relational database schema and establishes structural indexing."""
        conn = sqlite3.connect(self.db_filename)
        cursor = conn.cursor()
        
        # Create table with matching data types
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS system_telemetry (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                timestamp TEXT NOT NULL,
                country_code TEXT,
                latitude REAL,
                longitude REAL,
                payload_raw TEXT
            )
        """)
        # Index coordinates for high-performance geospatial lookups
        cursor.execute("CREATE INDEX IF NOT EXISTS idx_coordinates ON system_telemetry(latitude, longitude)")
        conn.commit()
        conn.close()
        logging.info(f"[+] Relational Database Schema established natively in: {self.db_filename}")

    def fetch_live_stream_packet(self):
        """Fetches raw streaming tracking events directly from a live public API node."""
        # Using a reliable public API to pull random, real global user-agent tracking data
        url = "https://randomuser.me"
        req = urllib.request.Request(url)
        req.add_header('User-Agent', 'ZeroCool-Data-Stream-v9.0')

        try:
            with urllib.request.urlopen(req, timeout=3.0) as response:
                if response.status == 200:
                    raw_payload = json.loads(response.read().decode('utf-8'))
                    results = raw_payload.get("results", [])
                    if results:
                        location = results[0].get("location", {})
                        return {
                            "country": location.get("country", "Unknown"),
                            "lat": float(location.get("coordinates", {}).get("latitude", 0.0)),
                            "lon": float(location.get("coordinates", {}).get("longitude", 0.0)),
                            "raw_data": json.dumps(results[0])
                        }
        except Exception as e:
            logging.warning(f"[-] Network connection timeout: {str(e)}. Using local synthetic fallback stream.")
            
        # Fallback to local data loop if the network is constrained
        return {
            "country": random.choice(["US", "FR", "JP", "TR"]),
            "lat": round(random.uniform(-90.0, 90.0), 4),
            "lon": round(random.uniform(-180.0, 180.0), 4),
            "raw_data": '{"status": "synthetic_fallback"}'
        }

    def commit_record_to_database(self, data_packet):
        """Inserts data records safely into the relational database using explicit transactions."""
        conn = sqlite3.connect(self.db_filename)
        cursor = conn.cursor()
        try:
            cursor.execute("""
                INSERT INTO system_telemetry (timestamp, country_code, latitude, longitude, payload_raw)
                VALUES (?, ?, ?, ?, ?)
            """, (
                str(datetime.datetime.now()),
                data_packet["country"],
                data_packet["lat"],
                data_packet["lon"],
                data_packet["raw_data"]
            ))
            conn.commit()
            self.processed_count += 1
            return True
        except Exception as e:
            logging.error(f"[-] Database write transaction failure: {str(e)}")
            conn.rollback()
            return False
        finally:
            conn.close()

    def run_ingestion_pipeline(self):
        logging.info("[*] Starting high-concurrency external streaming data pipeline...")
        self.is_running = True
        print("\nPress Ctrl+C to safely stop the processing core and flush buffers.\n")
        time.sleep(1.0)

        while self.is_running:
            try:
                # 1. Fetch from live API data endpoints
                packet = self.fetch_live_stream_packet()
                
                # 2. Write straight to physical relational database tables
                success = self.commit_record_to_database(packet)
                
                if success and self.processed_count % 3 == 0:
                    logging.info(
                        f"[INGESTED] Count: {self.processed_count} | Node Location: {packet['country']} | Coordinates: [{packet['lat']}, {packet['lon']}]"
                    )
                
                # Maintain throttling to avoid hitting public API rate limit constraints
                time.sleep(1.0)
                
            except KeyboardInterrupt:
                logging.warning("[!] Interruption caught. Gracefully winding down active network threads...")
                self.is_running = False
                break

        logging.info(f"[+] Pipeline closed cleanly. Total records permanently stored: {self.processed_count}")

if __name__ == "__main__":
    engine = ProductionIngestionEngine()
    engine.run_ingestion_pipeline()
