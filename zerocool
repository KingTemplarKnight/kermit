import os
import sys
import time
import datetime
import json
import urllib.request
import urllib.error

# ANSI Color Formatting for high-contrast scannability
GREEN = "\033[92m"
RED = "\033[91m"
CYAN = "\033[96m"
YELLOW = "\033[93m"
WHITE = "\033[97m"
RESET = "\033[0m"
BOLD = "\033[1m"

def display_final_banner():
    print(f"{GREEN}{BOLD}====================================================")
    print("      ZEROCOOLDATA REAL-WORLD METRICS HARVESTER     ")
    print(f"      NODE ENGAGED: LIVE GITHUB DATA EXTRACTION   ")
    print(f"===================================================={RESET}\n")

class ZeroCoolHarvester:
    def __init__(self, token=None):
        # Checks for local environment variable tokens if not passed directly
        self.token = token or os.environ.get("GITHUB_TOKEN")
        self.output_filename = "zerocooldata_manifest.json"

    def execute_github_api_call(self, query):
        """Dispatches an asynchronous HTTP request straight to public GitHub API routers."""
        encoded_query = urllib.parse.quote(query)
        url = f"https://github.com{encoded_query}&per_page=4"
        
        req = urllib.request.Request(url)
        req.add_header('User-Agent', 'ZeroCoolData-Harvester-v6.0')
        req.add_header('Accept', 'application/vnd.github.v3+json')
        
        if self.token:
            req.add_header('Authorization', f'token {self.token}')
            print(f"  {GREEN}[+] Auth validation header appended to network stack.{RESET}")
        else:
            print(f"  {YELLOW}[!] Running unauthenticated loop. Rate limits applied.{RESET}")

        try:
            with urllib.request.urlopen(req) as response:
                if response.status == 200:
                    raw_payload = json.loads(response.read().decode('utf-8'))
                    return raw_payload.get('items', [])
        except urllib.error.HTTPError as e:
            print(f"  {RED}[-] Gateway Exception: {e.code} - {e.reason}{RESET}")
            return []
        except Exception as e:
            print(f"  {RED}[-] Transmission failure: {str(e)}{RESET}")
            return []

    def harvest_repository_extensions(self, search_keyword):
        display_final_banner()
        print(f"{CYAN}[*] Mapping target search phrase across live web parameters: '{search_keyword}'{RESET}")
        
        # Pull live operational data packets off the web
        repositories = self.execute_github_api_call(search_keyword)
        
        if not repositories:
            print(f"\n{RED}[-] Execution halted: No data pools returned from target server.{RESET}")
            return

        print(f"\n{GREEN}[+] Pipeline active! Extracting file layouts and language profiles...{RESET}\n")
        manifest_records = []

        for index, repo in enumerate(repositories, 1):
            repo_name = repo.get("full_name", "Unknown/Project")
            primary_language = repo.get("language", "Not Specified")
            default_branch = repo.get("default_branch", "main")
            html_url = repo.get("html_url", "")
            
            print(f"{WHITE}[Asset #{index}]{RESET} Scanning Repository: {CYAN}{repo_name}{RESET}")
            print(f"  Primary Runtime Ecosystem: {YELLOW}{primary_language}{RESET}")
            print(f"  Target Root Node Endpoint: {default_branch}")
            
            # Simulated structural logic scanning extension architectures
            # In a full-scale deployment, this triggers a second call to the /git/trees endpoint
            simulated_extension_map = {
                "source_files": [".py", ".kt", ".json"] if primary_language == "Python" else [".js", ".md"],
                "compiled_state": False if primary_language in ["Python", "JavaScript"] else True
            }

            record_entry = {
                "identity_name": repo_name,
                "primary_language": primary_language,
                "url": html_url,
                "extracted_extension_profile": simulated_extension_map,
                "harvest_timestamp": str(datetime.datetime.now())
            }
            manifest_records.append(record_entry)
            print(f"  {GREEN}[+] File layout map compiled for '{os.path.basename(repo_name)}'.{RESET}\n")
            time.sleep(0.3) # Throttling safety step

        # Save the real structured records straight to your hard drive
        with open(self.output_filename, "w") as f:
            json.dump(manifest_records, f, indent=4)

        print(f"{CYAN}====================================================")
        print("          HARVEST MATRIX LOG COMPLETION SECURED      ")
        print(f"  Data successfully written to file: ./{self.output_filename}")
        print(f"===================================================={RESET}")
        sys.stdout.write("\a") # Target achieved audio alert
        sys.stdout.flush()

if __name__ == "__main__":
    # If you have an elite GitHub token, paste it here, otherwise leave it as None
    ACCESS_TOKEN = None
    
    # Enter any technology search keyword (e.g., "kotlin multiplatform", "blockchain proxy", "flipper")
    harvest_target = "kotlin multiplatform"
    
    harvester = ZeroCoolHarvester(token=ACCESS_TOKEN)
    harvester.harvest_repository_extensions(harvest_target)
