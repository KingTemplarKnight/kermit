apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: zerocool-edge-ingress
  namespace: zerocool-mesh
  annotations:
    kubernetes.io/ingress.class: "nginx"
    # Edge Firewall Rule: Restrict max body sizes to prevent denial-of-service memory exhaustion
    nginx.ingress.kubernetes.io/proxy-body-size: "8m"
    # Force direct encryption layers over public interfaces
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
spec:
  tls:
  - hosts:
    - api.zerocool.local
    secretName: zerocool-tls-certs # Points to your cluster SSL certificate keys
  rules:
  - host: api.zerocool.local
    http:
      paths:
      - path: /api/zero_cool_core
        pathType: Prefix
        backend:
          service:
            name: zerocool-api-service # Maps directly to your load-balanced service proxy
            port:
              number: 5000
