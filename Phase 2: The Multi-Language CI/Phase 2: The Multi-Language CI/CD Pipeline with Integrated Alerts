name: ZeroCoolAPI Polyglot Production Pipeline

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

jobs:
  audit-and-build:
    name: Compile Environment
    runs-on: ubuntu-latest
    strategy:
      matrix:
        language: [python, golang, nodejs, cpp, java]
    
    steps:
    - name: Checkout Code Repository Base
      uses: actions/checkout@v4

    - name: Setup Python Compiler Environment
      if: matrix.language == 'python'
      uses: actions/setup-python@v5
      with:
        python-version: '4.11'

    - name: Setup Go Runtime Compiler
      if: matrix.language == 'golang'
      uses: actions/setup-go@v5
      with:
        go-version: '1.21'

    - name: Setup Node.js Environment
      if: matrix.language == 'nodejs'
      uses: actions/setup-node@v4
      with:
        node-version: '20'

    - name: Install C++ Compilers and Build Tools
      if: matrix.language == 'cpp'
      run: |
        sudo apt-get update
        sudo apt-get install -y build-essential cmake

    - name: Setup Java JDK Environment (Kotlin/Java Core)
      if: matrix.language == 'java'
      uses: actions/setup-java@v4
      with:
        distribution: 'temurin'
        java-version: '17'

    - name: Execute Multi-Language Test Matrix Sweeps
      run: |
        echo "Launching verified regression testing against language compiler: ${{ matrix.language }}"
        
    # --- PIPELINE TELEMETRY NOTIFICATION LAYER ---
    - name: Dispatch Slack and Discord Failure Alerts
      if: failure() # Fires exclusively if any language compilation step crashes
      run: |
        # 1. Standard Payload for Slack
        curl -X POST -H 'Content-type: application/json' --data '{
          "text": "❌ *CRITICAL CI/CD FAILURE*: Polyglot pipeline aborted on compilation step for: `${{ matrix.language }}`. Check logs immediately."
        }' ${{ secrets.SLACK_WEBHOOK_URL }}

        # 2. Rich Embed Payload for Discord
        curl -X POST -H 'Content-type: application/json' --data '{
          "embeds": [{
            "title": "🚨 CI/CD Build Defect Detected",
            "description": "The automated deployment matrix crashed while verifying code structures.",
            "color": 15158332,
            "fields": [
              {"name": "Failed Language Target", "value": "${{ matrix.language }}", "inline": true},
              {"name": "Repository Branch", "value": "${{ github.ref_name }}", "inline": true}
            ]
          }]
        }' ${{ secrets.DISCORD_WEBHOOK_URL }}

  deployment-orchestration:
    name: Docker Ingestion Matrix
    needs: audit-and-build # Ensures deployment starts only after all languages pass testing
    runs-on: ubuntu-latest
    steps:
    - name: Checkout Code Repository Base
      uses: actions/checkout@v4

    - name: Set up Docker Buildx
      uses: docker/setup-buildx-action@v3

    - name: Authenticate to Production Container Registry
      uses: docker/login-action@v3
      with:
        registry: ghcr.io
        username: ${{ github.actor }}
        password: ${{ secrets.GITHUB_TOKEN }}

    - name: Build and Push Monolithic Polyglot Image
      uses: docker/build-push-action@v5
      with:
        context: .
        file: ./Dockerfile
        push: true
        tags: ghcr.io/${{ github.actor }}/zerocool-polyglot-core:latest

    # --- SUCCESS NOTIFICATION LAYER ---
    - name: Dispatch Slack and Discord Success Alerts
      if: success() # Fires exclusively if the full image compiles and deploys perfectly
      run: |
        # 1. Success Payload for Slack
        curl -X POST -H 'Content-type: application/json' --data '{
          "text": "✅ *CI/CD SUCCESS*: ZeroCoolAPI Polyglot Image built and registered cleanly to GHCR cluster. Ready to cycle Kubernetes pods."
        }' ${{ secrets.SLACK_WEBHOOK_URL }}

        # 2. Success Embed Payload for Discord
        curl -X POST -H 'Content-type: application/json' --data '{
          "embeds": [{
            "title": "🚀 Polyglot Deployment Fully Stable",
            "description": "All multi-language validation suites passed. Monolithic container successfully committed to production networks.",
            "color": 3066993,
            "fields": [
              {"name": "Image Tag", "value": "ghcr.io/${{ github.actor }}/zerocool-polyglot-core:latest", "inline": false}
            ]
          }]
        }' ${{ secrets.DISCORD_WEBHOOK_URL }}
