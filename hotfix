name: Python Package Pipeline

on:
  push:
    branches: [ main, master, "hotfix/**" ] # Added native pattern targeting hotfix branches
  pull_request:
    branches: [ main, master ]

jobs:
  build:
    runs-on: ubuntu-latest
    strategy:
      matrix:
        python-version: ["3.10"]

    steps:
    - name: Checkout repository
      uses: actions/checkout@v4

    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: ${{ matrix.python-version }}

    - name: Hotfix Go (Execute Hot-Patching Remediation)
      # This step acts as our 'hotfix-go' sequence to cleanse invisible layout corruptions on Line 1
      run: |
        echo "Running critical file hotfix patch..."
        sed -i '1s/^[^#a-zA-Z0-9_]*//' autonomous_module.py
        
    - name: Lint and Run Autonomous Module
      run: |
        python autonomous_module.py

    - name: Initialize Database Schema (SQLite Hotfix)
      if: always() # Prevents failure dropouts if preceding tests fail
      run: |
        python -c "
        import sqlite3
        
        # Connect to target build database safely
        conn = sqlite3.connect('build.db')
        cursor = conn.cursor()
        
        # Hot-patch structural layout table to stop OperationalErrors
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS build_logs (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
                version TEXT,
                status TEXT,
                log_text TEXT
            );
        ''')
        
        # Track active environment state
        status = 'SUCCESS' if '${{ job.status }}' == 'success' else 'FAILED'
        cursor.execute(
            'INSERT INTO build_logs (version, status, log_text) VALUES (?, ?, ?)',
            ('${{ matrix.python-version }}', status, 'Execution runtime marked as: ' + status)
        )
        conn.commit()
        conn.close()
        "

    - name: Alert Team on Failure
      if: failure()
      run: |
        curl -X POST -H 'Content-type: application/json' \
        --data '{"text": "❌ *CONDA BUILD FAILURE*: Python package pipeline crashed on version `${{ matrix.python-version }}`."}' \
        ${{ secrets.WEBHOOK_URL }}

        curl -X POST -H 'Content-type: application/json' \
        --data '{"embeds": [{"title": "🚨 Conda Matrix Defect", "description": "Python regression tests failed inside the Conda sandbox.", "color": 15158332, "fields": [{"name": "Python Version", "value": "${{ matrix.python-version }}", "inline": true}]}]}' \
        ${{ secrets.WEBHOOK_URL }}
